# Pegue sua chave em https://aistudio.google.com/app/apikey
# Plano gratuito: 1500 requisições/dia no Gemini 2.5 Flash
GEMINI_API_KEY=

# Modelo de texto (default: gemini-2.5-flash)
# Outras opções: gemini-2.5-pro (mais inteligente, mais lento)
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Modelo de imagem
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
